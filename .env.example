# Angel One Trading Dashboard Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# Angel One API Configuration
# These are example values - replace with your actual Angel One credentials
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PIN=your_pin_here
ANGEL_ONE_TOTP_SECRET=your_totp_secret_here

# Security Configuration
SESSION_SECRET=your_session_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Optional: Database Configuration (if using persistent storage)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=angel_one_dashboard
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password